NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# Base URL for `src/network` (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mapbox GL (maps in Command Center; workspace path: INTERNAL_DASHBOARD_ROUTES.workspace in src/lib/internal-dashboard-routes.ts). Public token is safe in the browser.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional custom styles (mapbox://…). You can use PUBLIC_* names instead; next.config forwards them to the client.
# NEXT_PUBLIC_MAPBOX_STYLE_URL=mapbox://styles/…
# NEXT_PUBLIC_MAPBOX_STYLE_URL_DARK=mapbox://styles/…?…
